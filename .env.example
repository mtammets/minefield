PORT=3000

# Required for donations:
STRIPE_SECRET_KEY=
# Recommended for production-grade donation verification:
STRIPE_WEBHOOK_SECRET=whsec_...

# Recommended in production (public HTTPS origin of your app):
STRIPE_DONATE_BASE_URL=http://localhost:3000

# Optional. Comma-separated explicit allowlist for Socket.IO origins.
SOCKET_ALLOWED_ORIGINS=

# Optional donate settings:
STRIPE_DONATE_CURRENCY=usd
STRIPE_DONATE_PRODUCT_NAME=Support Minefield Drift

# Optional Google Analytics 4 (loaded only after cookie consent):
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional Supabase auth + storage:
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database access for automatic schema bootstrap:
SUPABASE_DB_URL=
SUPABASE_DB_POOLER_URL=

# Optional storage bucket overrides:
SUPABASE_PROFILE_IMAGES_BUCKET=profile-images
SUPABASE_CAR_WRAPS_BUCKET=car-wraps
SUPABASE_GARAGE_WRAP_PRESETS_BUCKET=garage-wrap-presets
SUPABASE_BILLBOARD_MEDIA_BUCKET=billboard-media
SUPABASE_SHOWROOM_INTRO_BUCKET=showroom-intro-media

# Optional editor allowlist for billboard/showroom media management:
BILLBOARD_EDITOR_USER_IDS=
